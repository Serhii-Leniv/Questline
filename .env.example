# Questline — environment template. Copy to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# --- Database (used by backend + docker-compose Postgres) ---
POSTGRES_DB=questline
POSTGRES_USER=questline
POSTGRES_PASSWORD=change-me-local-password

# How the backend reaches Postgres.
# Local (backend on host, DB in docker-compose): jdbc:postgresql://localhost:5432/questline
# Inside docker-compose (backend container):      jdbc:postgresql://db:5432/questline
DB_URL=jdbc:postgresql://localhost:5432/questline
DB_USER=questline
DB_PASSWORD=change-me-local-password

# --- AI provider ---
# Default is Google Gemini. To use any OpenAI-compatible endpoint instead — a cloud provider
# (Groq, OpenRouter) or a LOCAL model (Ollama, LM Studio, vLLM) — set AI_PROVIDER=openai and the
# OPENAI_* vars below. No code changes; the ai/ LlmClient seam is provider-agnostic.
# AI_PROVIDER=google-genai

# Google Gemini (Google AI Studio free tier — NOT Vertex AI). Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible provider (only when AI_PROVIDER=openai). base-url is the host root; Spring AI
# appends /v1/.... Ollama: http://localhost:11434 · LM Studio: http://localhost:1234 ·
# Groq: https://api.groq.com/openai. Local servers accept any non-empty key.
# OPENAI_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.1

# --- Auth: Google OAuth2 (Google Cloud Console > Credentials) ---
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- JWT signing (HS256). Must be >= 32 bytes. Generate a random secret. ---
JWT_SECRET=generate-a-long-random-secret-at-least-32-bytes

# --- Encryption for users' stored BYOK provider API keys (AES-GCM). Optional; defaults to JWT_SECRET. ---
# APP_CRYPTO_SECRET=generate-another-long-random-secret

# --- Frontend ---
# Where the backend redirects after successful OAuth login.
FRONTEND_URL=http://localhost:5173
