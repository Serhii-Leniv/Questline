# Normalize line endings: LF in the repo for text files.
* text=auto eol=lf

# Windows batch scripts must stay CRLF.
*.bat text eol=crlf

# The Gradle wrapper script must be LF (runs on Linux CI).
gradlew text eol=lf

# Binary files — never normalize.
*.jar binary
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
